#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HARNESS_ROOT=""

resolve_harness_root() {
    local root
    root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
    HARNESS_ROOT="$root/docs/project-harness"
}

resolve_harness_root

usage() {
    cat <<'USAGE'
Usage: scripts/harness/harnessctl <command> [options]

Workflow commands:
  assign <item-id> <owner> <session-id> [--actor coordinator] [--branch BRANCH]
                               Assign an item and claim a lease without starting implementation
  accept <item-id> <owner> <session-id> [--branch BRANCH]
                               Accept an assigned item and move it to running
  start <item-id> <owner> <session-id> [--force --reason TEXT]
                               Compatibility shortcut: accept/start item as running
  release <item-id> <actor> [--force --reason TEXT]
                               Release ownership and lease
  decline <item-id> <actor> [--summary TEXT]
                               Decline an assigned or handed-off item
  renew-lease <item-id> <owner> <session-id> [--lease-minutes N]
                               Renew current owner/session lease
  unblock <item-id> <actor> --decision TEXT [--force --reason TEXT]
                               Move a blocked item back to todo with an auditable decision
  handoff <item-id> <target> [--actor coordinator] [--reason TEXT]
                               Generate current/handoff-packet.md and event
  review-result <item-id> <reviewer> <approved|changes_requested|blocked> [--summary TEXT]
                               Record reviewer decision
  mark-done <item-id> [actor] [--force --reason TEXT]
                               Mark done only after approved review, unless forced

Packet and state commands:
  sync <item-id>               Refresh current/task_plan.md from canonical plan
  state                        Refresh harness-state.json
  session-init [--skip-checklist] [--skip-typecheck] [--skip-tests]
                               Run deterministic session bootstrap
  review <item-id> [reviewer]  Generate current/review-packet.md and request review
  blocker <item-id> [--actor ACTOR] [--reason TEXT]
                               Generate current/blocker-packet.md and mark blocked
  closeout <item-id> [reviewer]
                               Generate current/closeout-packet.md; does not mark done
  validate [checklist-path]    Validate mvp-checklist.json
  doctor                       Health check for harness files

Options:
  -h, --help                   Show this help
USAGE
}

cmd="${1:-}"

case "${cmd}" in
    assign)
        item="${2:-}"
        owner="${3:-}"
        session="${4:-}"
        [[ -n "${item}" && -n "${owner}" && -n "${session}" ]] || { usage; exit 1; }
        shift 4
        python3 "$SCRIPT_DIR/workflow_transition.py" assign \
            --item "${item}" --owner "${owner}" --session "${session}" "$@"
        ;;
    accept)
        item="${2:-}"
        owner="${3:-}"
        session="${4:-}"
        [[ -n "${item}" && -n "${owner}" && -n "${session}" ]] || { usage; exit 1; }
        shift 4
        python3 "$SCRIPT_DIR/workflow_transition.py" accept \
            --item "${item}" --owner "${owner}" --session "${session}" "$@"
        ;;
    start)
        item="${2:-}"
        owner="${3:-}"
        session="${4:-}"
        [[ -n "${item}" && -n "${owner}" && -n "${session}" ]] || { usage; exit 1; }
        shift 4
        python3 "$SCRIPT_DIR/activate_item.py" --item "${item}" --owner "${owner}" --session "${session}" "$@"
        python3 "$SCRIPT_DIR/sync_current_from_item.py" --item "${item}"
        cat <<'EOF'

Reminder:
- If the canonical plan was just scaffolded, fill in tasks/<item-id>/plan.md first.
- Do not start implementation until the canonical plan has been completed and boundary-checked.
EOF
        ;;
    release)
        item="${2:-}"
        actor="${3:-}"
        [[ -n "${item}" && -n "${actor}" ]] || { usage; exit 1; }
        shift 3
        python3 "$SCRIPT_DIR/workflow_transition.py" release \
            --item "${item}" --actor "${actor}" "$@"
        ;;
    decline)
        item="${2:-}"
        actor="${3:-}"
        [[ -n "${item}" && -n "${actor}" ]] || { usage; exit 1; }
        shift 3
        python3 "$SCRIPT_DIR/workflow_transition.py" decline \
            --item "${item}" --actor "${actor}" "$@"
        ;;
    renew-lease)
        item="${2:-}"
        owner="${3:-}"
        session="${4:-}"
        [[ -n "${item}" && -n "${owner}" && -n "${session}" ]] || { usage; exit 1; }
        shift 4
        python3 "$SCRIPT_DIR/workflow_transition.py" renew-lease \
            --item "${item}" --owner "${owner}" --session "${session}" "$@"
        ;;
    unblock)
        item="${2:-}"
        actor="${3:-}"
        [[ -n "${item}" && -n "${actor}" ]] || { usage; exit 1; }
        shift 3
        python3 "$SCRIPT_DIR/workflow_transition.py" unblock \
            --item "${item}" --actor "${actor}" "$@"
        ;;
    handoff)
        item="${2:-}"
        target="${3:-}"
        [[ -n "${item}" && -n "${target}" ]] || { usage; exit 1; }
        shift 3
        python3 "$SCRIPT_DIR/prepare_handoff_packet.py" --item "${item}" --target "${target}" "$@"
        ;;
    review-result)
        item="${2:-}"
        reviewer="${3:-}"
        decision="${4:-}"
        [[ -n "${item}" && -n "${reviewer}" && -n "${decision}" ]] || { usage; exit 1; }
        shift 4
        python3 "$SCRIPT_DIR/workflow_transition.py" review-result \
            --item "${item}" --reviewer "${reviewer}" --decision "${decision}" "$@"
        ;;
    mark-done)
        item="${2:-}"
        actor="coordinator"
        [[ -n "${item}" ]] || { usage; exit 1; }
        if [ $# -ge 3 ] && [[ "${3}" != -* ]]; then
            actor="${3}"
            shift 3
        else
            shift 2
        fi
        python3 "$SCRIPT_DIR/workflow_transition.py" mark-done \
            --item "${item}" --actor "${actor}" "$@"
        ;;
    sync)
        item="${2:-}"
        [[ -n "${item}" ]] || { usage; exit 1; }
        python3 "$SCRIPT_DIR/sync_current_from_item.py" --item "${item}"
        ;;
    state)
        python3 "$SCRIPT_DIR/build_harness_state.py"
        ;;
    session-init)
        shift || true
        python3 "$SCRIPT_DIR/session_init.py" "$@"
        ;;
    review)
        item="${2:-}"
        reviewer="${3:-TBD}"
        [[ -n "${item}" ]] || { usage; exit 1; }
        python3 "$SCRIPT_DIR/prepare_review_packet.py" --item "${item}" --reviewer "${reviewer}"
        ;;
    blocker)
        item="${2:-}"
        [[ -n "${item}" ]] || { usage; exit 1; }
        shift 2
        python3 "$SCRIPT_DIR/prepare_blocker_packet.py" --item "${item}" "$@"
        ;;
    closeout)
        item="${2:-}"
        reviewer="${3:-TBD}"
        [[ -n "${item}" ]] || { usage; exit 1; }
        python3 "$SCRIPT_DIR/prepare_closeout_packet.py" --item "${item}" --reviewer "${reviewer}"
        ;;
    validate)
        shift || true
        if [ $# -gt 0 ]; then
            CHECKLIST_PATH="$1"
        else
            CHECKLIST_PATH="$HARNESS_ROOT/mvp-checklist.json"
        fi
        python3 "$SCRIPT_DIR/validate_checklist.py" "$CHECKLIST_PATH"
        ;;
    doctor)
        echo "=== Harness Doctor ==="
        echo ""

        echo "--- Required files ---"
        for f in mvp-checklist.json progress.md; do
            if [ -f "$HARNESS_ROOT/$f" ]; then
                echo "  OK  $f"
            else
                echo "  MISS  $f"
            fi
        done

        echo ""
        echo "--- Optional runtime files ---"
        for f in harness-config.json harness-state.json events.jsonl; do
            if [ -f "$HARNESS_ROOT/$f" ]; then
                echo "  OK  $f"
            else
                echo "  MISS  $f"
            fi
        done

        echo ""
        echo "--- Current pointer ---"
        if [ -f "$HARNESS_ROOT/current/task_plan.md" ]; then
            echo "  OK  current/task_plan.md exists"
        else
            echo "  MISS  current/task_plan.md"
        fi

        echo ""
        echo "--- Canonical plans ---"
        if [ -d "$HARNESS_ROOT/tasks" ]; then
            for item_dir in "$HARNESS_ROOT/tasks"/*/; do
                if [ -f "${item_dir}plan.md" ]; then
                    echo "  OK  $(basename "$item_dir")/plan.md"
                else
                    echo "  MISS  $(basename "$item_dir")/plan.md"
                fi
            done
        else
            echo "  No tasks/ directory"
        fi

        echo ""
        echo "--- Checklist validation ---"
        python3 "$SCRIPT_DIR/validate_checklist.py" "$HARNESS_ROOT/mvp-checklist.json" || true

        echo ""
        echo "--- Stale current check ---"
        if [ -f "$HARNESS_ROOT/current/task_plan.md" ] && [ -f "$HARNESS_ROOT/mvp-checklist.json" ]; then
            DOING_ID=$(python3 -c "
import json
try:
    data = json.load(open('$HARNESS_ROOT/mvp-checklist.json'))
    doing = [i for i in data['items'] if i.get('status') == 'doing']
    if len(doing) == 1:
        print(doing[0]['id'])
    elif len(doing) > 1:
        print('AMBIGUOUS')
    else:
        print('NONE')
except Exception:
    print('ERROR')
" 2>/dev/null)
            if [ "$DOING_ID" = "NONE" ]; then
                echo "  No item in doing status"
            elif [ "$DOING_ID" = "AMBIGUOUS" ]; then
                echo "  WARN: multiple items in doing status"
            elif [ "$DOING_ID" = "ERROR" ]; then
                echo "  ERROR: could not read checklist"
            else
                if [ -f "$HARNESS_ROOT/tasks/$DOING_ID/plan.md" ]; then
                    echo "  Current item: $DOING_ID"
                else
                    echo "  WARN: doing item $DOING_ID has no canonical plan"
                    echo "  Fix: scripts/harness/harnessctl start $DOING_ID <owner> <session>"
                fi
            fi
        else
            echo "  Cannot check (missing files)"
        fi

        echo ""
        echo "--- init.sh ---"
        if [ -f "$(git rev-parse --show-toplevel 2>/dev/null || pwd)/init.sh" ]; then
            echo "  OK  init.sh exists"
        else
            echo "  MISS  init.sh (optional - run initializer agent to generate)"
        fi

        echo ""
        echo "Doctor complete."
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        echo "Unknown command: ${1:-}"
        usage
        exit 1
        ;;
esac
